              "});\r",
              "\r",
              "pm.test(\"product_id was cleared\", function () {\r",
              "    pm.expect(pm.collectionVariables.get(\"product_id\")).to.be.undefined;\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is below 3000ms\", function () {\r",
