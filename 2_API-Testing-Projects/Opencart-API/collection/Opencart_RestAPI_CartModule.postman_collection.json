  "item": [
    {
      "name": "Create Session/Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "var jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Checking success msg in response\", () => {\r",
              "    pm.expect(jsonData.success).to.eql(\"Success: API session successfully started!\");\r",
              "});\r",
              "\r",
              "pm.collectionVariables.set(\"api_token_val\", jsonData.api_token);\r",
              "\r",
              "\r",
              "pm.test(\"api_token is a string and not empty\", function () {\r",
              "    pm.expect(jsonData.api_token).to.be.a(\"string\").and.not.empty;\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is below 3000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);\r",
              "});\r",
              "\r",
              "\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
