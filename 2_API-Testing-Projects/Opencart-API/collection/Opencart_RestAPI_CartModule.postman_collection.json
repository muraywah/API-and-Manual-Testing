    {
      "name": "Cart Content",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "var jsonData = pm.response.json();\r",
              "pm.environment.set(\"card_id_key\", jsonData.products[0].cart_id);\r",
              "\r",
              "pm.test(\"Products array is not empty\", function () {\r",
              "    pm.expect(jsonData.products).to.be.an(\"array\").and.not.empty;\r",
              "});\r",
              "\r",
              "pm.test(\"First product has a name\", function () {\r",
              "    pm.expect(jsonData.products[0]).to.have.property(\"name\");\r",
              "    pm.expect(jsonData.products[0].name).to.be.a(\"string\").and.not.empty;\r",
              "});\r",
              "\r",
              "pm.test(\"First product has a quantity\", function () {\r",
              "    pm.expect(jsonData.products[0]).to.have.property(\"quantity\");\r",
              "});\r",
              "\r",
              "pm.test(\"card_id_key was saved to environment\", function () {\r",
              "    pm.expect(pm.environment.get(\"card_id_key\")).to.not.be.undefined;\r",
              "    pm.expect(pm.environment.get(\"card_id_key\")).to.not.be.empty;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
