    {
      "name": "Get User Data",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "\r",
              "\r",
              "// pm.test(\"values of json fields\",() =>{ var jsonData = pm.response.json(); \r",
              "\r",
              "// pm.expect(jsonData.id).to.eql(pm.environment.get(\"userid\"));\r",
              "// pm.expect(jsonData.email.toString()).to.eql(pm.environment.get(\"email_env\")); \r",
              "//  pm.expect(jsonData.name).to.eql(pm.environment.get(\"name_env\")); \r",
              "// }\r",
              "// );\r",
              "\r",
              "pm.test(\"Values of JSON fields match environment\", () => { \r",
              "    let responseData = pm.response.json(); \r",
              "\r",
              "    // IF the response is a list/array, grab the first item inside it\r",
              "    if (Array.isArray(responseData)) {\r",
              "        responseData = responseData[0];\r",
              "    }\r",
              "\r",
              "    // Defensive check: Ensure we actually parsed data safely\r",
              "    pm.expect(responseData).to.be.an('object', 'Response payload could not be parsed as an object');\r",
              "    pm.expect(responseData.id).to.not.be.undefined;\r",
              "\r",
              "    // Debugging printouts to the console\r",
              "    console.log(\"Parsed API ID:\", responseData.id);\r",
              "    console.log(\"Parsed API Email:\", responseData.email);\r",
              "    console.log(\"Saved Env Email:\", pm.environment.get(\"email_env\"));\r",
              "\r",
              "    // Assertions\r",
              "    pm.expect(responseData.id.toString()).to.eql(pm.environment.get(\"userid\").toString());\r",
              "    pm.expect(responseData.email).to.eql(pm.environment.get(\"email_env\")); \r",
              "    pm.expect(responseData.name).to.eql(pm.environment.get(\"name_env\")); \r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
